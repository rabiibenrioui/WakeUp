{
  "cli": {
    "version": ">=18.0.6",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "hooks": {
        "pre-install": "./eas-build-pre-install.sh"
      }
    },
    "production": {
      "autoIncrement": true,
      "hooks": {
        "pre-install": "./eas-build-pre-install.sh"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
